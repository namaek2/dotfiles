    "pulseaudio": {
	"format": "{icon}",
  	"format-muted": "≤░ΨΒ",
  	"on-click": "~/.config/hypr/scripts/Volume.sh --toggle",
  	"on-click-right": "pavucontrol -t 3",
  	/*"on-scroll-up": "~/.config/hypr/scripts/Volume.sh --inc",
  	"on-scroll-down": "~/.config/hypr/scripts/Volume.sh --dec",*/
  	"format-icons": {
	    "headphone": "ΎΑξ",
            "hands-free": "ΎΑξ",
            "headset": "ΎΑξ",
	    "default": ["ΎΑο","ΎΑπ","≤░Χ╛"]
	}
    },

    "battery": {
      "bat": "BAT0",
      "adapter": "ADP0",
      "interval": 60,
      "states": {
          "warning": 20,
          "critical": 10
      },
      "max-length": 20,
      "format": "{icon}",
      "format-warning": "{icon} {capacity}%",
      "format-critical": "{icon} {capacity}%",
      "format-charging": "<span font-family='Font Awesome 6 Free'>ΎΔπ</span>",
      "format-plugged": "≤▒αΨ", 

      "format-alt": "{icon} {capacity}%",
      "format-full": "Ύχμ", 
      "format-icons": ["≤▒Λκ", "≤▒Λλ", "≤▒Λμ"],
      "on-click-right": "~/.config/waybar/scripts/battery_report.sh"
    },
